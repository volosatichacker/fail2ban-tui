install_fail2ban() {
  echo -e "${YELLOW}$MSG_INSTALL_PROMPT${NC}"
  read -rp "" confirm_install
  if [[ ! "$confirm_install" =~ ^[Yy]$ ]]; then
    echo -e "${RED}$MSG_INSTALL_CANCEL${NC}"
    exit 1
  fi

  echo -e "\n${BOLD}${WHITE}$MSG_INSTALL_START${NC}"

  # Detect Package Manager
  if command -v apt-get &> /dev/null; then
    echo -e "$MSG_INSTALL_APT_UPDATE"
    apt-get update -qq >/dev/null 2>&1
    echo -e "$MSG_INSTALL_APT_INSTALL"
    apt-get install -y fail2ban >/dev/null 2>&1
  elif command -v dnf &> /dev/null; then
    echo -e "$MSG_INSTALL_DNF_EPEL"
    dnf install -y epel-release >/dev/null 2>&1
    echo -e "$MSG_INSTALL_DNF_INSTALL"
    dnf install -y fail2ban >/dev/null 2>&1
  elif command -v yum &> /dev/null; then
    echo -e "$MSG_INSTALL_YUM_EPEL"
    yum install -y epel-release >/dev/null 2>&1
    echo -e "$MSG_INSTALL_YUM_INSTALL"
    yum install -y fail2ban >/dev/null 2>&1
  else
    echo -e "${RED}$MSG_INSTALL_ERR_PM${NC}"
    exit 1
  fi

  # Verify installation
  if ! command -v fail2ban-client &> /dev/null; then
    echo -e "${RED}$MSG_INSTALL_ERR_FAIL${NC}"
    exit 1
  fi

  # Basic configuration
  echo -e "$MSG_INSTALL_CONFIG"
  cat << 'EOF' > /etc/fail2ban/jail.local
[DEFAULT]
bantime = 1d
findtime = 10m
maxretry = 5

[sshd]
enabled = true
port = ssh
filter = sshd
backend = systemd
EOF

  echo -e "$MSG_INSTALL_START_SVC"
  systemctl daemon-reload >/dev/null 2>&1
  systemctl enable fail2ban --now >/dev/null 2>&1

  echo -e "${GREEN}${BOLD}$MSG_INSTALL_OK${NC}"
  sleep 2
}

