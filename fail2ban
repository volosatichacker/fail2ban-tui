get_ip_info() {
  local ip=$1
  # Use curl to query ip-api.com, parse with jq if installed, or simple grep/sed
  if command -v jq &> /dev/null; then
    local res=$(curl -s --max-time 2 "http://ip-api.com/json/$ip")
    local country=$(echo "$res" | jq -r '.country // "Unknown"')
    local org=$(echo "$res" | jq -r '.org // "Unknown"')
    echo "$country | $org"
  else
    local res=$(curl -s --max-time 2 "http://ip-api.com/json/$ip")
    local country=$(echo "$res" | grep -o '"country":"[^"]*' | cut -d'"' -f4)
    local org=$(echo "$res" | grep -o '"org":"[^"]*' | cut -d'"' -f4)
    [ -z "$country" ] && country="$MSG_UNKNOWN"
    [ -z "$org" ] && org="$MSG_UNKNOWN"
    echo "$country | $org"
  fi
}

show_header() {
  clear
  echo -e "${GRAY}================================================================${NC}"
  echo -e "  ${BOLD}${GREEN}$MSG_TITLE${NC}  "
  echo -e "  $MSG_HOST: ${CYAN}$(hostname)${NC} | $MSG_TIME: ${YELLOW}$(date '+%Y-%m-%d %H:%M:%S')${NC}"
  echo -e "${GRAY}================================================================${NC}"
}

show_status() {
  show_header
  echo -e "\n${BOLD}${WHITE}$MSG_STATUS_TITLE${NC}"
  local service_status=$(systemctl is-active fail2ban)
  if [ "$service_status" = "active" ]; then
    echo -e "    $MSG_STATUS_ACTIVE"
  else
    echo -e "    $MSG_STATUS_INACTIVE"
  fi
  
  # List Jails
  local jails=$(fail2ban-client status | grep "Jail list:" | sed 's/`- Jail list:\t//' | tr -d ',')
  echo -e "\n${BOLD}${WHITE}$MSG_ACTIVE_JAILS${NC}"
  for jail in $jails; do
    local stats=$(fail2ban-client status "$jail")
    local currently_banned=$(echo "$stats" | grep "Currently banned:" | awk '{print $4}')
    local total_banned=$(echo "$stats" | grep "Total banned:" | awk '{print $4}')
    echo -e "    • ${BOLD}${CYAN}$jail${NC} ($MSG_JAIL_BANNED: ${YELLOW}$currently_banned${NC} | $MSG_JAIL_TOTAL: ${GRAY}$total_banned${NC})"
  done
}

update_jail_local_config() {
  local jail=$1
  local key=$2
  local val=$3
  local file="/etc/fail2ban/jail.local"
  
  if [ -f "$file" ]; then
    python3 -c "
import configparser
config = configparser.ConfigParser(strict=False, interpolation=None)
config.read('$file')
if not config.has_section('$jail'):
    config.add_section('$jail')
config.set('$jail', '$key', '$val')
with open('$file', 'w') as f:
    config.write(f)
" 2>/dev/null
  fi
}

configure_jail_settings() {
  local jail=$1
  while true; do
    show_header
    echo -e "\n${BOLD}${WHITE}$MSG_ACTION_SETTINGS для ${CYAN}$jail${NC}"
    echo -e "${GRAY}----------------------------------------------------------------${NC}"
    
    local curr_bantime=$(fail2ban-client get "$jail" bantime)
    local curr_findtime=$(fail2ban-client get "$jail" findtime)
    local curr_maxretry=$(fail2ban-client get "$jail" maxretry)
    
    echo -e "    ${GREEN}1.${NC} $MSG_SETTING_BANTIME [ $MSG_CURRENT_VAL: ${YELLOW}$curr_bantime сек${NC} ]"
    echo -e "    ${GREEN}2.${NC} $MSG_SETTING_FINDTIME [ $MSG_CURRENT_VAL: ${YELLOW}$curr_findtime сек${NC} ]"
    echo -e "    ${GREEN}3.${NC} $MSG_SETTING_MAXRETRY [ $MSG_CURRENT_VAL: ${YELLOW}$curr_maxretry${NC} ]"
    echo -e "    ${GREEN}4.${NC} $MSG_ACTION_BACK"
    echo -e "${GRAY}----------------------------------------------------------------${NC}"
    echo ""
    read -rp "1-4: " set_choice
    
    local key=""
    case $set_choice in
      1) key="bantime" ;;
      2) key="findtime" ;;
      3) key="maxretry" ;;
      4) break ;;
      *)
        echo -e "${RED}$MSG_INVALID_CHOICE${NC}"
        sleep 1
        continue
        ;;
    esac
    
    read -rp "$MSG_ENTER_NEW_VALUE" new_val
    if [ -n "$new_val" ]; then
      # Apply via fail2ban-client
      local res=$(fail2ban-client set "$jail" "$key" "$new_val")
      # Save permanently in jail.local
      update_jail_local_config "$jail" "$key" "$new_val"
      
      echo -e "${GREEN}$MSG_SETTING_OK${NC}"
      sleep 2
    fi
  done
}

manage_jail() {
  local jail=$1
  while true; do
    show_header
    echo -e "\n${BOLD}${WHITE}$MSG_MANAGE_JAIL: ${CYAN}$jail${NC}"
    echo -e "${GRAY}----------------------------------------------------------------${NC}"
    
    local stats=$(fail2ban-client status "$jail")
    local currently_failed=$(echo "$stats" | grep "Currently failed:" | cut -d':' -f2 | xargs)
    local total_failed=$(echo "$stats" | grep "Total failed:" | cut -d':' -f2 | xargs)
    local currently_banned=$(echo "$stats" | grep "Currently banned:" | cut -d':' -f2 | xargs)
    local total_banned=$(echo "$stats" | grep "Total banned:" | cut -d':' -f2 | xargs)
    
    echo -e "    $MSG_FAILED_NOW: ${YELLOW}$currently_failed${NC} | $MSG_FAILED_TOTAL: ${GRAY}$total_failed${NC}"
    echo -e "    $MSG_JAIL_BANNED:       ${RED}${BOLD}$currently_banned${NC} | $MSG_JAIL_TOTAL:   ${GRAY}$total_banned${NC}"
    echo -e "${GRAY}----------------------------------------------------------------${NC}"
    
    echo -e "\n${BOLD}${WHITE}$MSG_BANNED_IP_LIST${NC}"
    local ips=$(echo "$stats" | grep "Banned IP list:" | sed 's/`- Banned IP list:\t//' | sed 's/|  |- Banned IP list:\t//')
    if [ -z "$ips" ]; then
      echo -e "    ${GRAY}$MSG_BANNED_EMPTY${NC}"
    else
      # Print header for table (colors defined inside format string, NOT in variable values)
      printf "    %-18s | %-15s | %-25s\n" "$MSG_COL_IP" "$MSG_COL_COUNTRY" "$MSG_COL_ORG"
      printf "    %-18s+%-17s+%-25s\n" "------------------" "-----------------" "-------------------------"
      for ip in $ips; do
        local ip_info=$(get_ip_info "$ip")
        local country=$(echo "$ip_info" | cut -d'|' -f1 | xargs)
        local org=$(echo "$ip_info" | cut -d'|' -f2 | xargs)
        # Apply ANSI colors in format string itself so column sizes align correctly
        printf "    ${RED}%-18s${NC} | %-15s | ${GRAY}%-25s${NC}\n" "$ip" "$country" "$org"
      done
    fi
    echo -e "${GRAY}----------------------------------------------------------------${NC}"
    
    echo -e "\n${BOLD}${WHITE}$MSG_ACTIONS${NC}"
    echo -e "    ${GREEN}1.${NC} $MSG_ACTION_UNBAN"
    echo -e "    ${GREEN}2.${NC} $MSG_ACTION_BAN"
    echo -e "    ${GREEN}3.${NC} $MSG_ACTION_SETTINGS"
    echo -e "    ${GREEN}4.${NC} $MSG_ACTION_BACK"
    echo ""
    read -rp "1-4: " action_choice
    
    case $action_choice in
      1)
        read -rp "$MSG_ENTER_UNBAN_IP" unban_ip
        if [ -n "$unban_ip" ]; then
          local res=$(fail2ban-client set "$jail" unbanip "$unban_ip")
          echo -e "${GREEN}$MSG_RESULT:${NC} $res"
          sleep 2
        fi
        ;;
      2)
        read -rp "$MSG_ENTER_BAN_IP" ban_ip
        if [ -n "$ban_ip" ]; then
          local res=$(fail2ban-client set "$jail" banip "$ban_ip")
          echo -e "${GREEN}$MSG_RESULT:${NC} $res"
          sleep 2
        fi
        ;;
      3)
        configure_jail_settings "$jail"
        ;;
      4)
        break
        ;;
      *)
        echo -e "${RED}$MSG_INVALID_CHOICE${NC}"
        sleep 1
        ;;
    esac
  done
}

while true; do
  show_status
  echo -e "\n${BOLD}${WHITE}$MSG_MAIN_MENU${NC}"
  
  # Dynamic Jails Menu
  jails=$(fail2ban-client status | grep "Jail list:" | sed 's/`- Jail list:\t//' | tr -d ',')
  index=1
  jail_array=()
  for jail in $jails; do
    echo -e "    ${GREEN}$index.${NC} $MSG_JAIL_STATS: ${BOLD}${CYAN}$jail${NC}"
