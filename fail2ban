    echo -e "${GRAY}----------------------------------------------------------------${NC}"
    tail -n 100 -f /var/log/fail2ban.log
  elif [ "$main_choice" -ge 1 ] 2>/dev/null && [ "$main_choice" -lt "$log_choice_idx" ] 2>/dev/null; then
    selected_jail=${jail_array[$((main_choice - 1))]}
    manage_jail "$selected_jail"
  else
    echo -e "${RED}$MSG_INVALID_CHOICE${NC}"
    sleep 1
  fi
done
