BOLD=$'\e[1m'

# Check if run as root
if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}${BOLD}Ошибка:${NC} Этот скрипт должен быть запущен от имени root (sudo fail2ban)."
  exit 1
fi

# Language configuration file
LANG_CONF="/etc/fail2ban/fail2ban_tui.conf"

load_language() {
  if [ -f "$LANG_CONF" ]; then
    source "$LANG_CONF"
  else
    clear
    echo "========================================"
    echo "  Select Language / Выберите язык       "
    echo "========================================"
    echo "  1. English"
    echo "  2. Русский"
    echo "========================================"
    read -rp "Enter choice [1-2]: " lang_choice
    if [ "$lang_choice" = "2" ]; then
      echo 'TUI_LANG="ru"' > "$LANG_CONF"
    else
      echo 'TUI_LANG="en"' > "$LANG_CONF"
    fi
    source "$LANG_CONF"
  fi
}

load_language

ensure_norkn_ban() {
  local action_file="/etc/fail2ban/action.d/norkn-ban.conf"
  local jail_local="/etc/fail2ban/jail.local"
  local helper_script="/usr/local/bin/fail2ban-report-ban"

  # Create or update the helper script
  cat << 'EOF' > "$helper_script"
#!/bin/bash
# Fail2ban IP Reporter Helper
IP="$1"
JAIL="$2"

if [ -n "$IP" ]; then
  curl -s --connect-timeout 5 --max-time 10 -X POST \
    -H "Content-Type: application/json" \
    -d "{\"ip\": \"$IP\", \"reason\": \"Banned by fail2ban jail $JAIL\", \"userAgent\": \"Fail2ban TUI Bot\"}" \
    https://banned.norkn.ru/api/ban >/dev/null 2>&1
fi
EOF
  chmod +x "$helper_script"

  # Create or update the action file
  mkdir -p /etc/fail2ban/action.d
  cat << 'EOF' > "$action_file"
[Definition]
actionban = /usr/local/bin/fail2ban-report-ban "<ip>" "<name>"
actionunban =
EOF

  # Ensure jail.local exists
  if [ ! -f "$jail_local" ]; then
    touch "$jail_local"
  fi

  local needs_restart=0
  
  # Check if jail.local already contains norkn-ban
  if ! grep -q "norkn-ban" "$jail_local"; then
    python3 -c "
import configparser
import os
file = '$jail_local'
config = configparser.ConfigParser(strict=False, interpolation=None)
config.read(file)
curr_action = config.defaults().get('action', '')
if 'norkn-ban' not in curr_action:
    if not curr_action:
        new_action = '%(action_)s norkn-ban[name=%(__name__)s]'
    else:
        new_action = curr_action + ' norkn-ban[name=%(__name__)s]'
    config.set('DEFAULT', 'action', new_action)
    with open(file, 'w') as f:
        config.write(f)
" 2>/dev/null
    needs_restart=1
  fi

  if [ "$needs_restart" -eq 1 ]; then
    echo -e "${YELLOW}$MSG_SETUP_NORKN${NC}"
    systemctl restart fail2ban >/dev/null 2>&1
    sleep 1
  fi
}

# Non-interactive setup flag
if [ "$1" = "--setup" ] || [ "$1" = "-s" ]; then
  # Quietly ensure fail2ban is installed (non-interactive auto-install if missing)
  if ! command -v fail2ban-client &> /dev/null; then
    echo -e "${YELLOW}[+] Auto-installing Fail2ban...${NC}"
    if command -v apt-get &> /dev/null; then
      apt-get update -qq >/dev/null 2>&1
      apt-get install -y fail2ban >/dev/null 2>&1
    elif command -v dnf &> /dev/null; then
      dnf install -y epel-release >/dev/null 2>&1
      dnf install -y fail2ban >/dev/null 2>&1
    elif command -v yum &> /dev/null; then
      yum install -y epel-release >/dev/null 2>&1
      yum install -y fail2ban >/dev/null 2>&1
    fi
    # Basic configuration
    cat << 'EOF' > /etc/fail2ban/jail.local
[DEFAULT]
bantime = 1d
findtime = 10m
maxretry = 5

[sshd]
enabled = true
port = ssh
filter = sshd
backend = systemd
EOF
    systemctl daemon-reload >/dev/null 2>&1
    systemctl enable fail2ban --now >/dev/null 2>&1
  fi
  ensure_norkn_ban
  echo -e "${GREEN}✓ Fail2ban TUI integration setup completed successfully!${NC}"
  exit 0
fi

